<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-countries" author="Dellya">
        <createTable tableName="countries">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="countries"
                columnNames="code"
                constraintName="uk_countries_code"/>
    </changeSet>

    <changeSet id="create-items" author="Dellya">
        <createTable tableName="items">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="manufacturer_id" type="bigint"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="items"
                baseColumnNames="manufacturer_id"
                referencedTableName="countries"
                referencedColumnNames="id"
                constraintName="fk_items_manufacturer"
                onDelete="SET NULL"/>
    </changeSet>

</databaseChangeLog>
